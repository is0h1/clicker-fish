#:import from_hex kivy.utils.get_color_from_hex
#:import to_rgba kivy.utils.rgba
#:import colormap kivy.utils.colormap

#:set main_color '#ef852e'
#:set main_color_dark "#c96e24"

<Widget>:
    font_name: 'assets/Lemon-Regular.ttf'

<ButtonMenu@Button>:
    font_size: "56sp"
    bold: True
    background_color: 0, 0, 0, 0
    size_hint: None, None
    pos_hint: {"center_x": 0.5}
    width: self.texture_size[0] + dp(40)   # ширина = текст + відступи

    canvas.before:
        Color:
            rgba: colormap['white']
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [self.font_size]
        Color:
            rgba: from_hex(main_color) if self.state == 'normal' else from_hex(main_color_dark)
        RoundedRectangle:
            size: self.size[0] - dp(6), self.size[1] - dp(6)
            pos: self.pos[0] + dp(3), self.pos[1] + dp(3)
            radius: [self.font_size]


<ButtonIcon@ButtonMenu>:
    font_name: 'assets/typicons.ttf'

<Menu>:
    BoxLayout:
        orientation: "vertical"
        padding: "30dp"
        spacing: "20dp"

        canvas:
            Rectangle:
                source: 'assets/images/back_menu.png'
                size: dp(750), self.size[1]
                pos: self.center_x - dp(750) / 2, self.self.y

        Widget:
            size_hint_y: 0.05

        Label:
            text: "UNDERWATER\nCLICKER"
            font_size: "54sp"
            halign: "center"
            size_hint_y: 0.15

        Image:
            source: "assets/images/title.png"
            allow_stretch: True
            size_hint_y: 0.5

        ButtonMenu:
            text: " PLAY "
            size_hint_y: 0.15

            on_press:
                root.manager.current = "game"
                root.manager.transition.direction = "left"
        BoxLayout:
            size_hint_y: 0.15
            # Button "Settings"
            ButtonIcon:
                text: "\uE04F"
                on_press:
                    root.go_settings()
            Widget:
            # Button "Exit"
            ButtonIcon:
                text: "\uE121"
                on_press:
                    app.stop()